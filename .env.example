# MongoDB Connection String
# For local dev: mongodb://localhost:27017/queuedoc
# For production: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/queuedoc
MONGODB_URI=

# Socket.IO Server URL (Optional for production)
# In production, if served monolithically, it connects to '/' automatically.
# For local dev, this can be set to http://localhost:3001 if needed.
VITE_SERVER_URL=
